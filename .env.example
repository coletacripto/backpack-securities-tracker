# Mode: webhook or poll
MODE=webhook

# Telegram
TELEGRAM_BOT_TOKEN=123456:telegram-bot-token
TELEGRAM_CHAT_ID=123456789

# Solana token mint to monitor
TOKEN_MINT=BPxxfRCXkUVhig4HS1Lh7kZqV6SPJhzfEk4x6fVBjPCy

# Alert threshold
USD_THRESHOLD=30000

# Price source.
# If FIXED_TOKEN_PRICE_USD is empty, the bot tries Jupiter by token mint.
# If Jupiter fails and COINGECKO_ID is set, it falls back to CoinGecko.
FIXED_TOKEN_PRICE_USD=
COINGECKO_ID=

# Optional label shown in Telegram messages
TOKEN_SYMBOL=TOKEN

# Webhook mode
WEBHOOK_SECRET=change-me
HOST=0.0.0.0
PORT=8080

# Poll mode.
# Use one or more Solana addresses separated by commas.
# For complete token-wide coverage, use Helius webhooks instead of polling.
HELIUS_API_KEY=
WATCH_ADDRESSES=
POLL_INTERVAL_SECONDS=20
